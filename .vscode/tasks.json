{
    "tasks": [
        {
            "type": "shell",
            "label": "Build Game Debug X64",
            "windows": {"command": "${workspaceFolder}/build-window.bat Debug x64 Game"},  
            "problemMatcher": ["$gcc"],
            "options": {"cwd": "${workspaceFolder}"},
            "group":{
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "Build Game Release X64",
            "windows": {"command": "${workspaceFolder}/build-window.bat Release x64 Game"},  
            "problemMatcher": ["$gcc"],
            "options": {"cwd": "${workspaceFolder}"},
            "group":{
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "Build MMDApp Debug X64",
            "windows": {"command": "${workspaceFolder}/build-window.bat Debug x64 MMDApp"},  
            "problemMatcher": ["$gcc"],
            "options": {"cwd": "${workspaceFolder}"},
            "group":{
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "Build MMDApp Release X64",
            "windows": {"command": "${workspaceFolder}/build-window.bat Release x64 MMDApp"},  
            "problemMatcher": ["$gcc"],
            "options": {"cwd": "${workspaceFolder}"},
            "group":{
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}